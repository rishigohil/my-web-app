---
const links = [
  {
    name: "facebook",
    url: "https://www.facebook.com/rishig10",
    alt: "Connect with me on Facebook",
  },
  {
    name: "twitter",
    url: "https://twitter.com/rishi_gohil10",
    alt: "Connect with me on Twitter",
  },
  {
    name: "linkedin",
    url: "https://www.linkedin.com/in/rishigohil",
    alt: "Connect with me on LinkedIn",
  },
  {
    name: "github",
    url: "https://github.com/rishigohil",
    alt: "Connect with me on GitHub",
  },
  {
    name: "soundcloud",
    url: "https://soundcloud.com/rishi_gohil",
    alt: "Connect with me on SoundCloud",
  },
  {
    name: "envelope",
    url: "mailto:rishi.gohil@live.com",
    alt: "Click here to Email me",
  },
];
---

<ul
  class="social-icons inline-flex list-none items-center justify-center gap-1 p-0"
>
  {
    links.map((item) => (
      <li class="inline-block">
        <a
          href={item.url}
          title={item.alt}
          aria-label={item.alt}
          target={item.name === "envelope" ? undefined : "_blank"}
          rel={
            item.name === "envelope" ? undefined : "noopener noreferrer"
          }
          class:list={["icon", `icon-${item.name}`]}
        >
          {item.name === "facebook" && (
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="currentColor"
              aria-hidden="true"
              width="18"
              height="18"
            >
              <path d="M22 12a10 10 0 1 0-11.56 9.88v-6.99H7.9V12h2.54V9.8c0-2.51 1.5-3.9 3.78-3.9 1.1 0 2.24.2 2.24.2v2.46h-1.26c-1.24 0-1.63.77-1.63 1.56V12h2.78l-.45 2.89h-2.33v6.99A10 10 0 0 0 22 12z" />
            </svg>
          )}
          {item.name === "twitter" && (
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="currentColor"
              aria-hidden="true"
              width="18"
              height="18"
            >
              <path d="M22.46 6c-.77.35-1.6.58-2.46.69a4.3 4.3 0 0 0 1.88-2.37 8.59 8.59 0 0 1-2.72 1.04 4.28 4.28 0 0 0-7.4 3.9A12.14 12.14 0 0 1 3 4.79a4.28 4.28 0 0 0 1.32 5.71 4.27 4.27 0 0 1-1.94-.54v.05a4.28 4.28 0 0 0 3.43 4.2 4.3 4.3 0 0 1-1.93.07 4.28 4.28 0 0 0 4 2.97A8.6 8.6 0 0 1 2 19.07a12.13 12.13 0 0 0 6.57 1.93c7.88 0 12.2-6.53 12.2-12.2 0-.19 0-.37-.01-.56A8.7 8.7 0 0 0 22.46 6z" />
            </svg>
          )}
          {item.name === "linkedin" && (
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="currentColor"
              aria-hidden="true"
              width="18"
              height="18"
            >
              <path d="M20.45 20.45h-3.55v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.13 1.45-2.13 2.94v5.67H9.36V9h3.41v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.45v6.29zM5.34 7.43a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12zM7.12 20.45H3.56V9h3.56v11.45zM22.22 0H1.78C.79 0 0 .77 0 1.72v20.56C0 23.23.79 24 1.78 24h20.44c.99 0 1.78-.77 1.78-1.72V1.72C24 .77 23.21 0 22.22 0z" />
            </svg>
          )}
          {item.name === "github" && (
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="currentColor"
              aria-hidden="true"
              width="18"
              height="18"
            >
              <path d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.44 9.8 8.21 11.39.6.11.82-.26.82-.58 0-.29-.01-1.05-.02-2.06-3.34.73-4.04-1.61-4.04-1.61-.55-1.39-1.34-1.76-1.34-1.76-1.09-.74.08-.73.08-.73 1.21.09 1.85 1.24 1.85 1.24 1.07 1.84 2.81 1.31 3.5 1 .11-.78.42-1.31.76-1.61-2.66-.3-5.47-1.33-5.47-5.93 0-1.31.47-2.38 1.24-3.22-.13-.3-.54-1.52.11-3.18 0 0 1.01-.32 3.3 1.23a11.5 11.5 0 0 1 6 0c2.29-1.55 3.3-1.23 3.3-1.23.66 1.66.25 2.88.12 3.18.77.84 1.24 1.91 1.24 3.22 0 4.61-2.81 5.62-5.49 5.92.43.37.81 1.1.81 2.22 0 1.6-.01 2.89-.01 3.29 0 .32.22.7.83.58A12 12 0 0 0 24 12c0-6.63-5.37-12-12-12z" />
            </svg>
          )}
          {item.name === "soundcloud" && (
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="currentColor"
              aria-hidden="true"
              width="20"
              height="20"
            >
              <path d="M1.18 14.74c.07 0 .12-.05.13-.12l.27-2.13-.27-2.18a.13.13 0 0 0-.13-.12c-.07 0-.13.05-.14.12L.7 12.49l.34 2.13c.01.07.07.12.14.12zm1.31.46c.07 0 .12-.05.13-.13l.36-2.59-.36-2.66a.14.14 0 0 0-.27 0L2 12.48l.35 2.59c0 .08.07.13.14.13zm1.36.18c.08 0 .15-.06.16-.14l.34-2.77-.34-2.86a.16.16 0 0 0-.32 0L3.4 12.5l.3 2.74c.01.08.08.14.16.14zm1.39.05c.09 0 .16-.07.17-.16l.32-2.77-.32-2.92a.17.17 0 0 0-.34 0L4.79 12.5l.3 2.77c.01.09.08.16.17.16zm1.4-.04c.1 0 .18-.08.19-.18l.3-2.71-.3-2.87a.19.19 0 0 0-.38 0l-.27 2.87.27 2.71c.01.1.09.18.19.18zm1.41-.07c.11 0 .2-.09.2-.2l.28-2.62-.28-2.83a.2.2 0 0 0-.41 0l-.25 2.83.25 2.62c.01.11.1.2.21.2zm1.41.04c.12 0 .22-.1.22-.22l.27-2.59-.27-2.96a.22.22 0 0 0-.44 0l-.24 2.96.24 2.59c0 .12.1.22.22.22zm1.42.05c.13 0 .23-.1.23-.23l.25-2.55-.25-3.13a.23.23 0 0 0-.46 0l-.22 3.13.22 2.55c0 .13.1.23.23.23zm1.5.02c.13 0 .24-.11.25-.25l.23-2.51-.23-3.36a.25.25 0 0 0-.5 0l-.2 3.36.2 2.51c.01.14.12.25.25.25zm9.62-3.51c-.6 0-1.18.13-1.69.36-.34-3.84-3.55-6.86-7.46-6.86-.96 0-1.89.18-2.74.5-.33.13-.42.26-.42.51v9.6c0 .28.21.49.48.51h11.83c2.16 0 3.91-1.74 3.91-3.91 0-2.16-1.75-3.91-3.91-3.91z" />
            </svg>
          )}
          {item.name === "envelope" && (
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="currentColor"
              aria-hidden="true"
              width="18"
              height="18"
            >
              <path d="M2 6.5A2.5 2.5 0 0 1 4.5 4h15A2.5 2.5 0 0 1 22 6.5v.32l-10 5.83-10-5.83V6.5zm0 2.4v8.6A2.5 2.5 0 0 0 4.5 20h15a2.5 2.5 0 0 0 2.5-2.5V8.9l-9.5 5.54a1 1 0 0 1-1 0L2 8.9z" />
            </svg>
          )}
        </a>
      </li>
    ))
  }
</ul>

<style>
  /* Hover-color treatment ported from clothes.css. Each network keeps the
     same brand bg color it had in the AngularJS site; the icon is black
     by default and turns white on hover. */
  .icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    color: #000;
    text-decoration: none;
    transition:
      background-color 0.5s ease,
      color 0.5s ease;
  }
  .icon-facebook:hover {
    color: #fff;
    background-color: #3d5b99;
  }
  .icon-twitter:hover {
    color: #fff;
    background-color: #00aced;
  }
  .icon-linkedin:hover {
    color: #fff;
    background-color: #0073a4;
  }
  .icon-github:hover {
    color: #fff;
    background-color: #808080;
  }
  .icon-soundcloud:hover {
    color: #fff;
    background-color: #ff7512;
  }
  .icon-envelope:hover {
    color: #fff;
    background-color: #0072c6;
  }
</style>
