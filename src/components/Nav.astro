---
import ThemeToggle from "./ThemeToggle.astro";

const links = [
  { href: "/", label: "Home" },
  { href: "/about", label: "About" },
  { href: "/projects", label: "Projects" },
  { href: "/resume", label: "Resume" },
];

const path = Astro.url.pathname.replace(/\/$/, "") || "/";
---

<header
  class="sticky top-0 z-40 backdrop-blur-md border-b border-zinc-200/60 dark:border-zinc-800/60 bg-white/70 dark:bg-zinc-950/70"
>
  <nav
    class="mx-auto flex max-w-5xl items-center justify-between px-6 py-4"
    aria-label="Primary"
  >
    <a
      href="/"
      class="font-semibold tracking-tight text-zinc-900 dark:text-zinc-50 hover:opacity-80 transition-opacity"
    >
      rishigohil
    </a>
    <ul class="flex items-center gap-1 text-sm">
      {
        links
          .filter((l) => l.href !== "/")
          .map((l) => {
            const active =
              l.href === "/"
                ? path === "/"
                : path === l.href || path.startsWith(`${l.href}/`);
            return (
              <li>
                <a
                  href={l.href}
                  aria-current={active ? "page" : undefined}
                  class:list={[
                    "px-3 py-1.5 rounded-md transition-colors",
                    active
                      ? "text-zinc-900 dark:text-zinc-50 bg-zinc-100 dark:bg-zinc-800"
                      : "text-zinc-600 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-zinc-50 hover:bg-zinc-100/60 dark:hover:bg-zinc-800/60",
                  ]}
                >
                  {l.label}
                </a>
              </li>
            );
          })
      }
      <li class="ml-1">
        <ThemeToggle />
      </li>
    </ul>
  </nav>
</header>
