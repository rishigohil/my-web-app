---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Not found" description="Page not found.">
  <section
    class="mx-auto flex max-w-3xl flex-col items-center px-6 py-32 text-center"
  >
    <p
      class="text-2xl font-mono text-zinc-700 dark:text-zinc-300"
      aria-hidden="true"
    >
      (╯°□°)╯︵ ┻━┻
    </p>
    <h1 class="mt-6 text-4xl font-semibold tracking-tight">Page not found</h1>
    <p class="mt-3 max-w-md text-zinc-600 dark:text-zinc-400">
      The page you&rsquo;re looking for doesn&rsquo;t exist or has moved.
    </p>
    <div class="mt-8 flex gap-3">
      <a
        href="/"
        class="rounded-md bg-zinc-900 px-4 py-2 text-sm font-medium text-white hover:bg-zinc-700 dark:bg-zinc-100 dark:text-zinc-900 dark:hover:bg-white"
        >Home</a
      >
      <a
        href="/projects"
        class="rounded-md border border-zinc-300 px-4 py-2 text-sm font-medium text-zinc-700 hover:bg-zinc-100 dark:border-zinc-700 dark:text-zinc-200 dark:hover:bg-zinc-900"
        >Projects</a
      >
    </div>
  </section>
</BaseLayout>
