---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="About" description="About Rishi Gohil.">
  <section class="mx-auto max-w-3xl px-6 py-20">
    <div class="flex flex-col items-start gap-8 sm:flex-row sm:items-center">
      <img
        src="/mypic.jpg"
        alt="Rishi Gohil"
        width="120"
        height="120"
        class="h-30 w-30 rounded-full object-cover ring-8 ring-zinc-200/60 dark:ring-zinc-800/60"
        loading="eager"
      />
      <div>
        <h1 class="text-4xl font-semibold tracking-tight">About</h1>
        <p class="mt-2 text-zinc-600 dark:text-zinc-400">
          Senior Software Engineer at <a
            href="https://www.anthologyinc.com"
            target="_blank"
            rel="noopener noreferrer"
            class="font-medium text-zinc-900 underline decoration-zinc-300 underline-offset-4 hover:decoration-zinc-900 dark:text-zinc-100 dark:decoration-zinc-700 dark:hover:decoration-zinc-100"
            >Anthology</a
          >.
        </p>
      </div>
    </div>

    <div
      class="mt-12 space-y-6 text-lg leading-relaxed text-zinc-700 dark:text-zinc-300"
    >
      <p>
        I&rsquo;m an ardent technologist, melomaniac, and gourmet. I spend
        most of my time writing code and listening to house music.
      </p>

      <p class="text-base text-zinc-500 dark:text-zinc-500">
        <em
          >TODO: Expand this with more career history, education, and what
          I&rsquo;m currently working on. The two-sentence bio above is the
          one preserved verbatim from the previous AngularJS site.</em
        >
      </p>
    </div>

    <div class="mt-12">
      <h2 class="text-xl font-semibold tracking-tight">Get in touch</h2>
      <ul
        class="mt-4 grid gap-2 text-sm text-zinc-700 dark:text-zinc-300 sm:grid-cols-2"
      >
        <li>
          <a
            href="mailto:rishi.gohil@live.com"
            class="hover:text-zinc-900 dark:hover:text-zinc-50"
            >rishi.gohil@live.com</a
          >
        </li>
        <li>
          <a
            href="https://github.com/rishigohil"
            target="_blank"
            rel="noopener noreferrer"
            class="hover:text-zinc-900 dark:hover:text-zinc-50">GitHub</a
          >
        </li>
        <li>
          <a
            href="https://www.linkedin.com/in/rishigohil"
            target="_blank"
            rel="noopener noreferrer"
            class="hover:text-zinc-900 dark:hover:text-zinc-50">LinkedIn</a
          >
        </li>
        <li>
          <a
            href="https://soundcloud.com/rishi_gohil"
            target="_blank"
            rel="noopener noreferrer"
            class="hover:text-zinc-900 dark:hover:text-zinc-50">SoundCloud</a
          >
        </li>
      </ul>
    </div>
  </section>
</BaseLayout>
