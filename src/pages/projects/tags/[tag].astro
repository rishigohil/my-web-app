---
import { getCollection } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import ProjectCard from "../../../components/ProjectCard.astro";

export async function getStaticPaths() {
  const all = await getCollection("projects");
  const tags = new Map<string, string>();
  for (const p of all) {
    for (const t of p.data.tech) {
      const slug = t.toLowerCase();
      if (!tags.has(slug)) tags.set(slug, t);
    }
  }

  return Array.from(tags.entries()).map(([slug, label]) => ({
    params: { tag: slug },
    props: {
      label,
      projects: all
        .filter((p) =>
          p.data.tech.some((t) => t.toLowerCase() === slug),
        )
        .sort((a, b) => b.data.date.getTime() - a.data.date.getTime()),
    },
  }));
}

const { label, projects } = Astro.props;
---

<BaseLayout
  title={`${label} projects`}
  description={`Projects tagged ${label}.`}
>
  <section class="mx-auto max-w-5xl px-6 py-20">
    <header class="mb-10">
      <p class="text-sm text-zinc-500 dark:text-zinc-500">
        <a
          href="/projects"
          class="hover:text-zinc-900 dark:hover:text-zinc-50"
        >
          ← All projects
        </a>
      </p>
      <h1 class="mt-2 text-4xl font-semibold tracking-tight">
        Tagged: <span class="text-zinc-500 dark:text-zinc-400">{label}</span>
      </h1>
    </header>

    <ul class="grid gap-6 sm:grid-cols-2">
      {
        projects.map((p) => (
          <li>
            <ProjectCard
              title={p.data.title}
              description={p.data.description}
              href={`/projects/${p.id}`}
              tech={p.data.tech}
              image={p.data.image}
            />
          </li>
        ))
      }
    </ul>
  </section>
</BaseLayout>
