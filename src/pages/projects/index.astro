---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import ProjectCard from "../../components/ProjectCard.astro";

const all = await getCollection("projects");
all.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const tags = [
  ...new Set(all.flatMap((p) => p.data.tech)),
].sort((a, b) => a.localeCompare(b));
---

<BaseLayout
  title="Projects"
  description="Things I've built — by Rishi Gohil."
>
  <section class="mx-auto max-w-5xl px-6 py-20">
    <header class="mb-10">
      <h1 class="text-4xl font-semibold tracking-tight">Projects</h1>
      <p class="mt-3 max-w-2xl text-zinc-600 dark:text-zinc-400">
        A growing list of things I&rsquo;ve built. Filter by stack below.
      </p>
    </header>

    {
      tags.length > 0 && (
        <nav aria-label="Filter projects by tag" class="mb-10">
          <ul class="flex flex-wrap gap-2">
            <li>
              <a
                href="/projects"
                class="rounded-md border border-zinc-900 bg-zinc-900 px-3 py-1 text-xs font-medium text-white dark:border-zinc-100 dark:bg-zinc-100 dark:text-zinc-900"
              >
                All
              </a>
            </li>
            {tags.map((tag) => (
              <li>
                <a
                  href={`/projects/tags/${encodeURIComponent(tag.toLowerCase())}/`}
                  class="rounded-md border border-zinc-200 px-3 py-1 text-xs font-medium text-zinc-700 hover:border-zinc-900 hover:bg-zinc-100 dark:border-zinc-800 dark:text-zinc-300 dark:hover:border-zinc-100 dark:hover:bg-zinc-900"
                >
                  {tag}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      )
    }

    {
      all.length === 0 ? (
        <p class="text-sm text-zinc-500 dark:text-zinc-500">
          No projects yet.
        </p>
      ) : (
        <ul class="grid gap-6 sm:grid-cols-2">
          {all.map((p) => (
            <li>
              <ProjectCard
                title={p.data.title}
                description={p.data.description}
                href={`/projects/${p.id}`}
                tech={p.data.tech}
                image={p.data.image}
              />
            </li>
          ))}
        </ul>
      )
    }
  </section>
</BaseLayout>
