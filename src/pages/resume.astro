---
import BaseLayout from "../layouts/BaseLayout.astro";

const driveUrl =
  "https://drive.google.com/file/d/0BwReR2Ov8DKMdzByZE1ZQS1TcVk/view?usp=sharing&resourcekey=0-bdPC317bEVdkUSFnsyI8VQ";
---

<BaseLayout title="Resume" description="Resume of Rishi Gohil.">
  <section class="resume-page mx-auto max-w-3xl px-6 py-20">
    <header class="mb-10">
      <h1 class="text-4xl font-semibold tracking-tight">Resume</h1>
      <p class="mt-3 text-zinc-600 dark:text-zinc-400">Coming soon.</p>
    </header>

    <div
      class="rounded-xl border border-dashed border-zinc-300 bg-zinc-50 p-8 text-center dark:border-zinc-700 dark:bg-zinc-900"
    >
      <p class="text-sm text-zinc-600 dark:text-zinc-400">
        A web-native resume page is on the way. In the meantime, you can{" "}
        <a
          href={driveUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="font-medium text-zinc-900 underline underline-offset-4 dark:text-zinc-100"
        >
          view the current PDF
        </a>{" "}
        or print this page once it&rsquo;s populated.
      </p>
    </div>

    {/* TODO: Replace the placeholder block above with real resume content. */}
    <article class="resume-content mt-12 hidden">
      <h2>Experience</h2>
      <p>TODO</p>

      <h2>Education</h2>
      <p>TODO</p>

      <h2>Skills</h2>
      <p>TODO</p>
    </article>
  </section>
</BaseLayout>

<style>
  /* Print scaffold — hide chrome, show resume content, single-column A4-ish layout. */
  @media print {
    :global(header),
    :global(footer),
    :global(nav) {
      display: none !important;
    }
    :global(html) {
      background: #fff !important;
      color: #000 !important;
    }
    :global(body) {
      background: #fff !important;
      color: #000 !important;
    }
    .resume-page {
      max-width: 100%;
      padding: 0;
      margin: 0;
    }
    .resume-content {
      display: block !important;
    }
    .resume-content h2 {
      font-size: 1.125rem;
      font-weight: 600;
      margin-top: 1.25rem;
      margin-bottom: 0.5rem;
      border-bottom: 1px solid #ccc;
      padding-bottom: 0.25rem;
    }
    @page {
      margin: 0.6in;
    }
  }
</style>
